# ============================================================
# 环境变量模板 —— 复制本文件为 .env 并填入真实值
#   cp .env.example .env
# 真实的 .env 已被 .gitignore 挡在库外,不会上传。本文件只是占位说明。
# ============================================================

# --- 数据位置(A→B 翻转点:指向真实 vault 即从 fixtures 切到真实数据)---
# 开发/自测时留空 → 默认用 fixtures/ 假数据
# 个人机/工作机接管时 → 填真实 vault 的绝对路径,无需改代码
WORK_VAULT_PATH=
PERSONAL_VAULT_PATH=

# --- Notion 适配层(可选;当前工作数据用 git 同步,已足够,可暂不填)---
NOTION_TOKEN=
NOTION_DATABASE_ID=

# --- 执行器 / 模型(按需填,当前阶段可全部留空)---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# 本地模型(如用 ollama)
OLLAMA_BASE_URL=http://localhost:11434
