# ============================================================
# 隐私保险丝 —— 这些文件永远不进 git,防止秘钥/真实数据泄漏
# system-code 是「可开源的框架仓」,绝不能混入任何真实私人数据
# ============================================================

# --- 秘钥 / 环境变量(真实 key、token 只落在本地 .env,永不入库)---
.env
.env.local
*.key
*.pem
secrets/

# --- 真实私人数据(只用 fixtures/ 假数据开发,真实 vault 在别的私有仓)---
vault-real/
work-vault/
personal-vault/
*.private.*
*.private/

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Node / Electron 前端 ---
node_modules/
ui/node_modules/
dist/
out/

# --- 系统 / 编辑器 ---
.DS_Store
.idea/
.vscode/
*.swp

# --- 本地临时输出 ---
*.log
tmp/
.cache/
